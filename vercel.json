{
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/ads.txt", "destination": "/ads.txt" },
    { "source": "/manifest.webmanifest", "destination": "/manifest.webmanifest" },

    { "source": "/google249552f9b2711a57.html", "destination": "/google249552f9b2711a57.html" },

    {
      "source": "/scripts/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|yandex|duckduckbot|slurp|baiduspider|applebot|facebookexternalhit|twitterbot|linkedinbot|slackbot|discordbot|telegrambot|whatsapp|pinterest|gptbot|chatgpt-user|claudebot|perplexitybot|oai-searchbot|youbot|anthropic-ai|cohere-ai|bytespider|ccbot|google-extended).*"
        }
      ],
      "destination": "/api/script?slug=:slug"
    },

    { "source": "/((?!api/|assets/|images/|videos/|.*\\.(?:xml|txt|json|js|css|png|jpg|jpeg|gif|svg|webp|ico|woff|woff2|ttf|otf|mp4|webmanifest|html)).*)", "destination": "/index.html" }
  ],
  "headers": [
    { "source": "/sitemap.xml", "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }] },
    { "source": "/robots.txt", "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }] }
  ]
}
